{
  "name": "notes-app",
  "version": "1.0.0",
  "description": "Simple note-taking app for GitOps demo",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "jest --coverage --threshold 80",
    "lint": "eslint ."
  },
  "dependencies": {
    "express": "^4.18.2",
    "prom-client": "^14.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.40.0",
    "jest": "^29.5.0",
    "newman": "^5.3.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverage": true,
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}

